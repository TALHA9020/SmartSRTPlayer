<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/subtitle_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="250dp"
        android:padding="12dp"
        android:background="#CC000000" 
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/timer_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="#FFEB3B"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اردو سبٹائٹل یہاں نظر آئے گا"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textAlignment="center"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/subtitle_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:background="#EE111111"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center">

        <ImageButton 
            android:id="@+id/btn_offset_minus" 
            android:layout_width="35dp" 
            android:layout_height="35dp" 
            android:src="@android:drawable/ic_media_previous" 
            android:background="?android:attr/selectableItemBackground" 
            android:contentDescription="Offset -" />

        <ImageButton 
            android:id="@+id/btn_backward" 
            android:layout_width="45dp" 
            android:layout_height="45dp" 
            android:src="@android:drawable/ic_media_rew" 
            android:background="?android:attr/selectableItemBackground" />

        <ImageButton 
            android:id="@+id/btn_play_pause" 
            android:layout_width="55dp" 
            android:layout_height="55dp" 
            android:src="@android:drawable/ic_media_play" 
            android:background="?android:attr/selectableItemBackground" />

        <ImageButton 
            android:id="@+id/btn_forward" 
            android:layout_width="45dp" 
            android:layout_height="45dp" 
            android:src="@android:drawable/ic_media_ff" 
            android:background="?android:attr/selectableItemBackground" />

        <ImageButton 
            android:id="@+id/btn_offset_plus" 
            android:layout_width="35dp" 
            android:layout_height="35dp" 
            android:src="@android:drawable/ic_media_next" 
            android:background="?android:attr/selectableItemBackground" 
            android:contentDescription="Offset +" />

        <ImageButton 
            android:id="@+id/btn_hide_bg" 
            android:layout_width="35dp" 
            android:layout_height="35dp" 
            android:src="@android:drawable/ic_menu_view" 
            android:background="?android:attr/selectableItemBackground" 
            android:tint="#FFEB3B" />

        <ImageButton 
            android:id="@+id/btn_close_service" 
            android:layout_width="35dp" 
            android:layout_height="35dp" 
            android:src="@android:drawable/ic_menu_close_clear_cancel" 
            android:background="?android:attr/selectableItemBackground" 
            android:tint="#F44336"
            android:layout_marginStart="4dp"
            android:contentDescription="Close" />

    </LinearLayout>
</RelativeLayout>
